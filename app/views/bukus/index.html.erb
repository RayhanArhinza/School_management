<!-- bukus/index.html.erb -->
<!-- Breadcrumb -->
<nav class="flex mb-6" aria-label="Breadcrumb">
  <ol class="inline-flex items-center space-x-1 md:space-x-2">
    <li class="inline-flex items-center">
      <a href="" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600">
        <i class="fas fa-book mr-2"></i>
        Perpustakaan
      </a>
    </li>
    <li aria-current="page">
      <div class="flex items-center">
        <i class="fas fa-chevron-right text-gray-400 mx-2"></i>
        <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">Book Management</span>
      </div>
    </li>
  </ol>
</nav>

<div class="bg-white rounded-lg shadow p-4 sm:p-6">
  <!-- Flash Messages -->
  <% flash.each do |type, message| %>
    <div id="notification" class="mb-4 p-4 rounded-lg <%= type == 'notice' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
      <%= message %>
    </div>
  <% end %>

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Manajemen Buku</h1>
    <button onclick="openModal('newBukuModal')" class="w-full sm:w-auto bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg flex items-center justify-center">
      <i class="fas fa-plus mr-2"></i> Buku Baru
    </button>
  </div>

<!-- Filter Form -->
<%= form_tag bukus_path, method: :get, class: "mb-4" do %>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4">
    <div>
      <label for="category" class="block text-sm font-medium text-gray-700 mb-2">Kategori</label>
      <%= select_tag :category, 
        options_for_select(@categories, params[:category]), 
        prompt: "Pilih Kategori",
        class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition" %>
    </div>

    <div>
      <label for="judul" class="block text-sm font-medium text-gray-700 mb-2">Judul</label>
      <%= text_field_tag :judul, 
        params[:judul], 
        class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition",
        placeholder: "Cari judul..." %>
    </div>

    <div>
      <label for="pengarang" class="block text-sm font-medium text-gray-700 mb-2">Pengarang</label>
      <%= text_field_tag :pengarang, 
        params[:pengarang], 
        class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition",
        placeholder: "Cari pengarang..." %>
    </div>

    <!-- Wrapper untuk tombol agar sejajar dengan field -->
    <div class="flex items-end gap-2 md:col-span-2">
      <%= submit_tag "Cari", 
        class: "px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>


      <%= link_to 'Reset', bukus_path, class: "px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-400 focus:outline-none" %>
    </div>
  </div>
<% end %>



<!-- Rest of your existing table code -->

  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden border border-gray-200 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Judul</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ISBN</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pengarang</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kategori</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Aksi</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @bukus.each do |buku| %>
              <tr class="hover:bg-gray-50">
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= buku.judul %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= buku.isbn %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= buku.pengarang %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= buku.category %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-3">
                    <button onclick="openModal('editBukuModal<%= buku.id %>')" class="text-blue-600 hover:text-blue-900">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button onclick="openModal('deleteBukuModal<%= buku.id %>')" class="text-red-600 hover:text-red-900">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>

              <!-- Edit Buku Modal -->
              <div id="editBukuModal<%= buku.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-lg shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Edit Buku</h3>
                    <%= form_with(model: buku, local: true, class: "mt-4") do |f| %>
                      <div class="grid grid-cols-1 gap-4 mt-2 px-4 sm:px-7 py-3">
                        <div>
                          <%= f.label :judul, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.text_field :judul, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <%= f.label :isbn, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.text_field :isbn, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <%= f.label :pengarang, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.text_field :pengarang, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <%= f.label :penerbit, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.text_field :penerbit, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <%= f.label :tahun_terbit, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.number_field :tahun_terbit, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <%= f.label :category, class: "block text-sm font-medium text-gray-700" %>
                          <%= f.text_field :category, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                      </div>
                      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                        <%= f.submit "Update", class: "w-full sm:w-auto px-4 py-2 bg-blue-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                        <button type="button" onclick="closeModal('editBukuModal<%= buku.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                          Batal
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Delete Confirmation Modal -->
              <div id="deleteBukuModal<%= buku.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-md shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Konfirmasi Hapus</h3>
                    <div class="mt-4 px-4 sm:px-7 py-3 text-center">
                      <p>Apakah Anda yakin ingin menghapus buku ini?</p>
                      <p class="text-sm text-gray-500 mt-1">Tindakan ini tidak dapat dibatalkan.</p>
                    </div>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                      <%= button_to buku_path(buku), method: :delete, class: "w-full sm:w-auto px-4 py-2 bg-red-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-300" do %>
                        Hapus
                      <% end %>
                      <button type="button" onclick="closeModal('deleteBukuModal<%= buku.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                        Batal
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="mt-6">
        <% if @bukus.total_pages > 1 %>
            <div class="flex justify-center">
            <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <!-- Previous Page Link -->
                <%= link_to(bukus_path(page: (@bukus.current_page - 1), category: params[:category], judul: params[:judul], pengarang: params[:pengarang]), 
                    class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@bukus.current_page == 1 ? 'cursor-not-allowed opacity-50' : ''}", 
                    disabled: @bukus.current_page == 1) do %>
                <span class="sr-only">Previous</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <% end %>

                <!-- Page Numbers -->
                <% page_window = 2 %>
                <% start_page = [1, @bukus.current_page - page_window].max %>
                <% end_page = [@bukus.total_pages, @bukus.current_page + page_window].min %>

                <% if start_page > 1 %>
                <%= link_to 1, bukus_path(page: 1, category: params[:category], judul: params[:judul], pengarang: params[:pengarang]), 
                    class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
                <% if start_page > 2 %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
                <% end %>
                <% end %>

                <% (start_page..end_page).each do |page_number| %>
                <%= link_to page_number, 
                    bukus_path(page: page_number, category: params[:category], judul: params[:judul], pengarang: params[:pengarang]), 
                    class: "relative inline-flex items-center px-4 py-2 border #{page_number == @bukus.current_page ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-gray-300 bg-white text-gray-700'} text-sm font-medium hover:bg-gray-50" %>
                <% end %>

                <% if end_page < @bukus.total_pages %>
                <% if end_page < @bukus.total_pages - 1 %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
                <% end %>
                <%= link_to @bukus.total_pages, 
                    bukus_path(page: @bukus.total_pages, category: params[:category], judul: params[:judul], pengarang: params[:pengarang]), 
                    class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
                <% end %>

                <!-- Next Page Link -->
                <%= link_to(bukus_path(page: (@bukus.current_page + 1), category: params[:category], judul: params[:judul], pengarang: params[:pengarang]), 
                    class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@bukus.current_page == @bukus.total_pages ? 'cursor-not-allowed opacity-50' : ''}", 
                    disabled: @bukus.current_page == @bukus.total_pages) do %>
                <span class="sr-only">Next</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <% end %>
            </nav>
            </div>
        <% end %>
        </div>
  </div>
</div>

<!-- New Buku Modal -->
<div id="newBukuModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-lg shadow-lg rounded-md bg-white">
    <div class="mt-3">
      <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Tambah Buku Baru</h3>
      <%= form_with(model: Buku.new, local: true, class: "mt-4") do |f| %>
        <div class="grid grid-cols-1 gap-4 mt-2 px-4 sm:px-7 py-3">
          <div>
            <%= f.label :judul, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :judul, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :isbn, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :isbn, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :pengarang, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :pengarang, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :penerbit, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :penerbit, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :tahun_terbit, class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :tahun_terbit, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :category, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :category, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
          <%= f.submit "Simpan", class: "w-full sm:w-auto px-4 py-2 bg-blue-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
          <button type="button" onclick="closeModal('newBukuModal')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
            Batal
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function openModal(modalId) {
    document.getElementById(modalId).classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(modalId) {
    document.getElementById(modalId).classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

// Auto-hide notifications
document.addEventListener('DOMContentLoaded', function() {
 const notification = document.getElementById('notification');
 if (notification) {
   setTimeout(function() {
     notification.style.transition = 'opacity 0.5s ease-in-out';
     notification.style.opacity = '0';
     setTimeout(function() {
       notification.remove();
     }, 500);
   }, 3000);
 }
});
</script>