<nav class="flex mb-6" aria-label="Breadcrumb">
  <ol class="inline-flex items-center space-x-1 md:space-x-2">
    <li class="inline-flex items-center">
      <a href="" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600">
        <i class="fas fa-school mr-2"></i>
        School Management
      </a>
    </li>
    <li aria-current="page">
      <div class="flex items-center">
        <i class="fas fa-chevron-right text-gray-400 mx-2"></i>
        <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">Student Management</span>
      </div>
    </li>
  </ol>
</nav>
<div class="bg-white rounded-lg shadow p-4 sm:p-6">
  <!-- Flash Messages for Notifications -->
  <% flash.each do |type, message| %>
    <div id="notification" class="mb-4 p-4 rounded-lg <%= type == 'notice' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
      <%= message %>
    </div>
  <% end %>

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Students Management</h1>
    <button onclick="openModal('newSiswaModal')" class="w-full sm:w-auto bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg flex items-center justify-center">
      <i class="fas fa-plus mr-2"></i> New Student
    </button>
  </div>

  <!-- Filter Form -->
<div class="mb-6">
  <%= form_with url: siswas_path, method: :get, local: true, class: "flex flex-col sm:flex-row md:flex-nowrap gap-4" do |form| %>
    <div class="flex-grow">
      <%= form.text_field :nama, value: params[:nama], placeholder: "Search by name", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>
    <div class="flex-grow">
      <%= form.collection_select :kelas_id, Kela.all, :id, :nama_kelas, { selected: params[:kelas_id], include_blank: "All Classes" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>
    <div class="flex flex-col sm:flex-row gap-2">
      <%= form.submit "Filter", class: "w-full sm:w-auto min-w-[150px] px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
      <%= link_to 'Reset', siswas_path, class: "w-full sm:w-auto text-center min-w-[150px] px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-400 focus:outline-none" %>
    </div>
  <% end %>
</div>


  <!-- Table -->
  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden border border-gray-200 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">NISN</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tanggal Lahir</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kelas</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">No HP</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alamat</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tanggal Bergabung</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Jenis Kelamin</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @siswas.each do |siswa| %>
              <tr class="hover:bg-gray-50">
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.nisn %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.name %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.tanggal_lahir %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.kela.nama_kelas if siswa.kela %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.no_hp %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.alamat %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.email %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.tanggal_bergabung %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= siswa.gender.name if siswa.gender %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-3">
                    <%= link_to siswa_path(siswa), class: "text-green-600 hover:text-green-900" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <button onclick="openModal('editSiswaModal<%= siswa.id %>')" class="text-blue-600 hover:text-blue-900">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button onclick="openModal('deleteSiswaModal<%= siswa.id %>')" class="text-red-600 hover:text-red-900">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>

              <!-- Edit Siswa Modal -->
              <div id="editSiswaModal<%= siswa.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-md shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Edit Student</h3>
                    <%= form_with(model: siswa, local: true, class: "mt-4") do |f| %>
                      <div class="mt-2 px-4 sm:px-7 py-3">
                        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500", placeholder: "Name" %>
                        <%= f.text_field :nisn, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2", placeholder: "NISN" %>
                        <%= f.text_field :nik, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2", placeholder: "NIK" %>
                        <%= f.date_field :tanggal_lahir, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2" %>
                        <%= f.collection_select :kelas_id, Kela.all, :id, :nama_kelas, { prompt: "Pilih Kelas" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2" %>
                        <%= f.text_field :no_hp, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2", placeholder: "No HP" %>
                        <%= f.text_area :alamat, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2", placeholder: "Alamat" %>
                        <%= f.text_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2", placeholder: "Email" %>
                        <%= f.date_field :tanggal_bergabung, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2" %>
                        <%= f.collection_select :jenis_kelamin, Gender.all, :id, :name, { prompt: "Pilih Jenis Kelamin" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2" %>
                        <%= f.collection_select :role_id, Role.all, :id, :name, { prompt: "Pilih Role" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 mt-2" %>
                      </div>
                      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                        <%= f.submit "Update", class: "w-full sm:w-auto px-4 py-2 bg-blue-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                        <button type="button" onclick="closeModal('editSiswaModal<%= siswa.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                          Cancel
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Delete Confirmation Modal -->
              <div id="deleteSiswaModal<%= siswa.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-md shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Confirm Delete</h3>
                    <div class="mt-4 px-4 sm:px-7 py-3 text-center">
                      <p>Are you sure you want to delete this student?</p>
                      <p class="text-sm text-gray-500 mt-1">This action cannot be undone.</p>
                    </div>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                      <%= button_to siswa_path(siswa), method: :delete, class: "w-full sm:w-auto px-4 py-2 bg-red-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-300" do %>
                        Delete
                      <% end %>
                      <button type="button" onclick="closeModal('deleteSiswaModal<%= siswa.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                        Cancel
                      </button>
                    </div>
                  </div>
                </div>
              </div>
                <!-- New Siswa Modal -->
              

            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
              <div id="newSiswaModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-lg shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Create New Student</h3>
                    <%= form_with(model: Siswa.new, local: true, class: "mt-4") do |f| %>
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-4 sm:px-7 py-3">
                        <div>
                          <label class="block text-gray-700">Name</label>
                          <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">NISN</label>
                          <%= f.text_field :nisn, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">NIK</label>
                          <%= f.text_field :nik, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Tanggal Lahir</label>
                          <%= f.date_field :tanggal_lahir, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Kelas</label>
                          <%= f.collection_select :kelas_id, Kela.all, :id, :nama_kelas, { prompt: "Pilih Kelas" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">No HP</label>
                          <%= f.text_field :no_hp, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div class="col-span-2">
                          <label class="block text-gray-700">Alamat</label>
                          <%= f.text_area :alamat, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Email</label>
                          <%= f.text_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Tanggal Bergabung</label>
                          <%= f.date_field :tanggal_bergabung, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Jenis Kelamin</label>
                          <%= f.collection_select :jenis_kelamin, Gender.all, :id, :name, { prompt: "Pilih Jenis Kelamin" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                        <div>
                          <label class="block text-gray-700">Role</label>
                          <%= f.collection_select :role_id, Role.all, :id, :name, { prompt: "Pilih Role" }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                        </div>
                      </div>
                      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                        <%= f.submit "Create", class: "w-full sm:w-auto px-4 py-2 bg-blue-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                        <button type="button" onclick="closeModal('newSiswaModal')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                          Cancel
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
  <!-- Pagination -->
  <div class="mt-6">
    <% if @siswas.total_pages > 1 %>
      <div class="flex justify-center">
        <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
          <!-- Previous Page Link -->
          <%= link_to(siswas_path(page: (@siswas.current_page - 1), nama: params[:nama], kelas_id: params[:kelas_id]), 
              class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@siswas.current_page == 1 ? 'cursor-not-allowed opacity-50' : ''}", 
              disabled: @siswas.current_page == 1) do %>
            <span class="sr-only">Previous</span>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          <% end %>

          <!-- Page Numbers -->
          <% page_window = 2 %>
          <% start_page = [1, @siswas.current_page - page_window].max %>
          <% end_page = [@siswas.total_pages, @siswas.current_page + page_window].min %>

          <% if start_page > 1 %>
            <%= link_to 1, siswas_path(page: 1, nama: params[:nama], kelas_id: params[:kelas_id]), 
                class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
            <% if start_page > 2 %>
              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
            <% end %>
          <% end %>

          <% (start_page..end_page).each do |page_number| %>
            <%= link_to page_number, 
                siswas_path(page: page_number, nama: params[:nama], kelas_id: params[:kelas_id]), 
                class: "relative inline-flex items-center px-4 py-2 border #{page_number == @siswas.current_page ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-gray-300 bg-white text-gray-700'} text-sm font-medium hover:bg-gray-50" %>
          <% end %>

          <% if end_page < @siswas.total_pages %>
            <% if end_page < @siswas.total_pages - 1 %>
              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
            <% end %>
            <%= link_to @siswas.total_pages, 
                siswas_path(page: @siswas.total_pages, nama: params[:nama], kelas_id: params[:kelas_id]), 
                class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
          <% end %>

          <!-- Next Page Link -->
          <%= link_to(siswas_path(page: (@siswas.current_page + 1), nama: params[:nama], kelas_id: params[:kelas_id]), 
              class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@siswas.current_page == @siswas.total_pages ? 'cursor-not-allowed opacity-50' : ''}", 
              disabled: @siswas.current_page == @siswas.total_pages) do %>
            <span class="sr-only">Next</span>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          <% end %>
        </nav>
      </div>
    <% end %>
  </div>
</div>



<script>
  function openModal(modalId) {
    document.getElementById(modalId).classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(modalId) {
    document.getElementById(modalId).classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  // Auto-hide notifications after 3 seconds
  document.addEventListener('DOMContentLoaded', function() {
    const notification = document.getElementById('notification');
    if (notification) {
      setTimeout(function() {
        notification.style.transition = 'opacity 0.5s ease-in-out';
        notification.style.opacity = '0';
        setTimeout(function() {
          notification.remove();
        }, 500);
      }, 3000);
    }
  });
</script>