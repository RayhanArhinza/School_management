<div class="bg-white rounded-lg shadow max-w-5xl mx-auto">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-xl font-semibold text-gray-800">Siswa Details</h2>
  </div>
  
  <div class="p-6">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      <div>
        <h3 class="text-sm font-medium text-gray-500">Nama Siswa</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.name %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">NISN</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.nisn %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">NIK</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.nik %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Tanggal Lahir</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.tanggal_lahir %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Kelas</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.kela.nama_kelas %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">No. HP</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.no_hp %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Alamat</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.alamat %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Email</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.email %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Tanggal Bergabung</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.tanggal_bergabung %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Jenis Kelamin</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.gender.name %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-500">Role</h3>
        <p class="mt-1 text-sm text-gray-900"><%= @siswa.role.name %></p>
      </div>
    </div>

    <div class="flex justify-end space-x-2 mt-6">
      <%= link_to "Back", siswas_path, class: "px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  </div>
</div>