<div class="bg-white rounded-lg shadow max-w-md mx-auto">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-xl font-semibold text-gray-800">Kelas Details</h2>
  </div>
  
  <div class="p-6">
    <div class="mb-4">
      <h3 class="text-sm font-medium text-gray-500">Nama Kelas</h3>
      <p class="mt-1 text-sm text-gray-900"><%= @kela.nama_kelas %></p>
    </div>

    <div class="mb-4">
      <h3 class="text-sm font-medium text-gray-500">Wali Kelas</h3>
      <p class="mt-1 text-sm text-gray-900"><%= @kela.guru&.user&.name %></p>

    </div>

    <div class="flex justify-end space-x-2">
      <%= link_to "Back", kelas_path, class: "px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  </div>
</div>