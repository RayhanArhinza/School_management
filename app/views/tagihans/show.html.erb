

<div class="max-w-4xl mx-auto my-6 bg-white shadow-lg rounded-md p-6">
  <h1 class="text-2xl font-semibold text-gray-900 text-center mb-6">Detail Peminjaman</h1>

  

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <!-- Buku -->
    <div>
      <h3 class="text-sm font-medium text-gray-700">Nama</h3>
      <p class="mt-1 text-gray-900"><%= @tagihan.nama %></p>
    </div>

    <!-- Siswa -->
    <div>
      <h3 class="text-sm font-medium text-gray-700">Siswa</h3>
      <p class="mt-1 text-gray-900"><%= @tagihan.biaya %></p>
    </div>

    <!-- Tanggal Tempo -->
    <div>
      <h3 class="text-sm font-medium text-gray-700">Tanggal Tempo</h3>
      <p class="mt-1 text-gray-900"><%= @tagihan.tanggal_tempo.strftime('%d %B %Y') %></p>
    </div>

    <!-- Tanggal Pembayaran -->
    <p class="mt-1 text-gray-900">
  <%= @tagihan.tanggal_pembayaran&.strftime('%d %B %Y')  %>
</p>


    <!-- Status -->
    <div>
      <h3 class="text-sm font-medium text-gray-700">Status</h3>
      <p class="mt-1 text-gray-900"><%= @tagihan.status.titleize %></p>
    </div>
  </div>

  <div class="mt-6">
    <!-- Tombol Edit dan Hapus -->
    <div class="flex justify-end gap-4">
        <%= link_to 'Kembali', tagihans_path, class: "px-4 py-2 bg-gray-500 text-white rounded-md hover:bg-gray-600" %>
     
    </div>
  </div>
</div>

