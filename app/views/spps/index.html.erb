<nav class="flex mb-6" aria-label="Breadcrumb">
  <ol class="inline-flex items-center space-x-1 md:space-x-2">
    <li class="inline-flex items-center">
      <a href="" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600">
        <i class="fas fa-school mr-2"></i>
        Financial Management
      </a>
    </li>
    <li aria-current="page">
      <div class="flex items-center">
        <i class="fas fa-chevron-right text-gray-400 mx-2"></i>
        <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">Tuition Management</span>
      </div>
    </li>
  </ol>
</nav>
<div class="bg-white rounded-lg shadow p-4 sm:p-6">
  <!-- Flash Messages for Notifications -->
  <% flash.each do |type, message| %>
    <div id="notification" class="mb-4 p-4 rounded-lg <%= type == 'notice' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
      <%= message %>
    </div>
  <% end %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center  gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-800 mb-6">Tuition Management</h1>
    <!-- Add this inside your existing filter form or near the table -->
    <div class="flex items-center gap-2">
      <%= link_to spps_path(format: :xlsx, tahun: params[:tahun], bulan: params[:bulan], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                  class: "px-4 py-2 bg-yellow-500 text-white rounded-md hover:bg-yellow-600 focus:outline-none flex items-center" do %>
        <i class="fas fa-file-excel mr-2"></i>Export to Excel
      <% end %>
    </div>
  </div>


  <!-- Filter Form -->
  <%= form_with url: spps_path, method: :get, class: "mb-4" do |form| %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-6 gap-4">
      <div>
        <%= form.label :tahun, "Tahun", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :tahun, options_for_select(@tahun_options, params[:tahun]), { include_blank: 'Pilih Tahun' }, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition" %>
      </div>
      <div>
        <%= form.label :bulan, "Bulan", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :bulan, options_for_select(Date::MONTHNAMES.compact, params[:bulan]), { include_blank: 'Pilih Bulan' }, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition" %>
      </div>
      <div>
        <%= form.label :nama_siswa, "Nama Siswa", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :nama_siswa, value: params[:nama_siswa], class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition" %>
      </div>
      <div>
        <%= form.label :lunas, "Status Pembayaran", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :lunas, options_for_select([['Paid', true], ['Unpaid', false]], params[:lunas]), { include_blank: 'Pilih Status' }, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 transition" %>
      </div>
      
      <!-- Wrapper untuk tombol agar sejajar dengan Status Pembayaran -->
      <div class="flex items-end gap-2 md:col-span-2">
        <%= form.submit "Filter", class: "px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
        <%= link_to 'Reset', spps_path, class: "px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-400 focus:outline-none" %>
      </div>
    </div>
  <% end %>


  <!-- Table -->
  <div class="overflow-x-auto -mx-4 sm:mx-0">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden border border-gray-200 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Year</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Month</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cost</th> <!-- Kolom baru -->
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @spps.each do |spp| %>
              <tr class="hover:bg-gray-50">
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= spp.id %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= spp.tahun %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= spp.bulan %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(spp.biaya, unit: "Rp", delimiter: ".", separator: ",") %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= spp.lunas ? 'Paid' : 'Unpaid' %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= spp.siswa.name %></td>
                <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-3">
                    <button onclick="openModal('editSppModal<%= spp.id %>')" class="text-blue-600 hover:text-blue-900">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button onclick="openModal('deleteSppModal<%= spp.id %>')" class="text-red-600 hover:text-red-900">
                      <i class="fas fa-trash"></i>
                    </button>
                    <!--<% if spp.lunas? %>
                      <%= link_to generate_invoice_spp_path(spp, format: :pdf), class: "text-green-600 hover:text-green-900", target: "_blank" do %>
                        <i class="fas fa-file-pdf"></i>
                      <% end %> -->
                    <% end %>
                    <%= link_to print_invoice_spp_path(spp), target: "_blank", class: "text-green-600 hover:text-green-900" do %>
                      <i class="fas fa-print"></i>
                    <% end %>
                  </div>
                </td>
              </tr>

              <!-- Edit SPP Modal -->
              <div id="editSppModal<%= spp.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-md shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Edit SPP</h3>
                    <%= form_with(model: spp, url: spp_path(spp), method: :patch, local: true, class: "mt-4") do |f| %>
                      <div class="mt-2 px-4 sm:px-7 py-3">
                        <%= f.label :biaya, "Cost", class: "block text-sm font-medium text-gray-700" %>
                        <%= f.number_field :biaya, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                      </div>
                      <div class="mt-2 px-4 sm:px-7 py-3">
                        <%= f.select :lunas, [['Paid', true], ['Unpaid', false]], { selected: spp.lunas }, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500" %>
                      </div>
                      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                        <%= f.submit "Update", class: "w-full sm:w-auto px-4 py-2 bg-blue-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                        <button type="button" onclick="closeModal('editSppModal<%= spp.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                          Cancel
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Delete Confirmation Modal -->
              <div id="deleteSppModal<%= spp.id %>" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
                <div class="relative top-20 mx-auto p-4 sm:p-5 border w-full max-w-sm sm:max-w-md shadow-lg rounded-md bg-white">
                  <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 text-center">Confirm Delete</h3>
                    <div class="mt-4 px-4 sm:px-7 py-3 text-center">
                      <p>Are you sure you want to delete this SPP?</p>
                      <p class="text-sm text-gray-500 mt-1">This action cannot be undone.</p>
                    </div>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-2 px-4 py-3">
                      <%= button_to spp_path(spp), method: :delete, class: "w-full sm:w-auto px-4 py-2 bg-red-500 text-white text-base font-medium rounded-md shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-300" do %>
                        Delete
                      <% end %>
                      <button type="button" onclick="closeModal('deleteSppModal<%= spp.id %>')" class="w-full sm:w-auto px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none">
                        Cancel
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    

    <!-- Pagination -->
    <div class="mt-6">
      <% if @spps.total_pages > 1 %>
        <div class="flex justify-center">
          <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
            <!-- Previous Page Link -->
            <%= link_to(spps_path(page: (@spps.current_page - 1), tahun: params[:tahun], bulan: params[:bulan], biaya: params[:biaya], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@spps.current_page == 1 ? 'cursor-not-allowed opacity-50' : ''}", 
                disabled: @spps.current_page == 1) do %>
              <span class="sr-only">Previous</span>
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            <% end %>

            <!-- Page Numbers -->
            <% page_window = 2 %>
            <% start_page = [1, @spps.current_page - page_window].max %>
            <% end_page = [@spps.total_pages, @spps.current_page + page_window].min %>

            <% if start_page > 1 %>
              <%= link_to 1, spps_path(page: 1, tahun: params[:tahun], bulan: params[:bulan], biaya: params[:biaya], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                  class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
              <% if start_page > 2 %>
                <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
              <% end %>
            <% end %>

            <% (start_page..end_page).each do |page_number| %>
              <%= link_to page_number, 
                  spps_path(page: page_number, tahun: params[:tahun], bulan: params[:bulan], biaya: params[:biaya], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                  class: "relative inline-flex items-center px-4 py-2 border #{page_number == @spps.current_page ? 'border-indigo-500 bg-indigo-50 text-indigo-600' : 'border-gray-300 bg-white text-gray-700'} text-sm font-medium hover:bg-gray-50" %>
            <% end %>

            <% if end_page < @spps.total_pages %>
              <% if end_page < @spps.total_pages - 1 %>
                <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700">...</span>
              <% end %>
              <%= link_to @spps.total_pages, 
                  spps_path(page: @spps.total_pages, tahun: params[:tahun], bulan: params[:bulan], biaya: params[:biaya], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                  class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50" %>
            <% end %>

            <!-- Next Page Link -->
            <%= link_to(spps_path(page: (@spps.current_page + 1), tahun: params[:tahun], bulan: params[:bulan], biaya: params[:biaya], nama_siswa: params[:nama_siswa], lunas: params[:lunas]), 
                class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 #{@spps.current_page == @spps.total_pages ? 'cursor-not-allowed opacity-50' : ''}", 
                disabled: @spps.current_page == @spps.total_pages) do %>
              <span class="sr-only">Next</span>
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </nav>
        </div>
      <% end %>
    </div>
  </div>
</div>
<script>
  function openModal(modalId) {
    document.getElementById(modalId).classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(modalId) {
    document.getElementById(modalId).classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  // Auto-hide notifications after 3 seconds
  document.addEventListener('DOMContentLoaded', function() {
    const notification = document.getElementById('notification');
    if (notification) {
      setTimeout(function() {
        notification.style.transition = 'opacity 0.5s ease-in-out';
        notification.style.opacity = '0';
        setTimeout(function() {
          notification.remove();
        }, 500);
      }, 3000);
    }
  });
</script>