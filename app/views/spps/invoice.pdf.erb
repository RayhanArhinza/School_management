<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Invoice SPP</title>
  <style>
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      line-height: 1.6;
      color: #2d3436;
      margin: 0;
      padding: 20px;
      background-color: #f7f7f7;
    }
    .invoice-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px;
      box-shadow: 0 0 20px rgba(0,0,0,0.1);
      background-color: #fff;
      border-radius: 8px;
    }
    .header {
      text-align: center;
      margin-bottom: 40px;
      position: relative;
      padding-bottom: 20px;
    }
    .header::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 150px;
      height: 3px;
      background: linear-gradient(to right, #3498db, #2980b9);
    }
    .header h1 {
      margin: 0;
      color: #2980b9;
      font-size: 28px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .invoice-number {
      color: #7f8c8d;
      font-size: 16px;
      margin-top: 10px;
    }
    .school-info {
      margin-bottom: 40px;
      padding: 20px;
      background-color: #f8f9fa;
      border-radius: 6px;
    }
    .school-info h2 {
      margin: 0 0 15px 0;
      font-size: 22px;
      color: #2c3e50;
    }
    .info-section {
      margin-bottom: 30px;
      padding: 20px;
      border-left: 4px solid #3498db;
      background-color: #f8f9fa;
    }
    .info-section h3 {
      margin: 0 0 15px 0;
      font-size: 18px;
      color: #2c3e50;
    }
    .table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
      box-shadow: 0 0 10px rgba(0,0,0,0.05);
    }
    .table th, .table td {
      border: 1px solid #e9ecef;
      padding: 15px;
      text-align: left;
    }
    .table th {
      background-color: #3498db;
      color: white;
      font-weight: 600;
    }
    .table tr:nth-child(even) {
      background-color: #f8f9fa;
    }
    .table tr:hover {
      background-color: #f1f3f4;
    }
    .total {
      text-align: right;
      font-size: 1.3em;
      font-weight: bold;
      margin-top: 30px;
      padding: 20px;
      background-color: #2980b9;
      color: white;
      border-radius: 6px;
    }
    .footer {
      margin-top: 50px;
      text-align: center;
      font-size: 0.9em;
      color: #7f8c8d;
      padding: 20px;
      border-top: 2px dashed #e9ecef;
    }
    .status-badge {
      display: inline-block;
      padding: 8px 15px;
      border-radius: 20px;
      font-weight: bold;
      text-transform: uppercase;
      font-size: 14px;
    }
    .status-paid {
      background-color: #27ae60;
      color: white;
    }
    .status-unpaid {
      background-color: #e74c3c;
      color: white;
    }
    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-bottom: 30px;
    }
  </style>
</head>
<body>
  <div class="invoice-container">
    <div class="header">
      <h1>Invoice Pembayaran SPP</h1>
      <div class="invoice-number">No. Invoice: INV-<%= @spp.id %></div>
    </div>

    <div class="school-info">
      <h2>SEKOLAH MENENGAH ATAS</h2>
      <p><i class="fas fa-map-marker-alt"></i> Jl. Pendidikan No. 123</p>
      <p><i class="fas fa-phone"></i> (021) 555-0123</p>
    </div>

    <div class="info-grid">
      <div class="info-section">
        <h3>Detail Invoice</h3>
        <p><strong>Tanggal:</strong> <%= Time.current.strftime("%d %B %Y") %></p>
        <p>
          <strong>Status:</strong> 
          <span class="status-badge <%= @spp.lunas ? 'status-paid' : 'status-unpaid' %>">
            <%= @spp.lunas ? 'LUNAS' : 'BELUM LUNAS' %>
          </span>
        </p>
      </div>

      <div class="info-section">
        <h3>Informasi Siswa</h3>
        <p><strong>Nama:</strong> <%= @spp.siswa.name %></p>
        <p><strong>Kelas:</strong> <%= @spp.siswa.kela.nama_kelas %></p>
        <p><strong>NISN:</strong> <%= @spp.siswa.nisn %></p>
      </div>
    </div>

    <div class="payment-info">
      <table class="table">
        <thead>
          <tr>
            <th>Deskripsi</th>
            <th>Periode</th>
            <th>Jumlah</th>
            <th>Status Pembayaran</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Pembayaran SPP</td>
            <td><%= @spp.bulan %> <%= @spp.tahun %></td>
            <td>Rp 500.000</td>
            <td>LUNAS</td>
          </tr>
        </tbody>
      </table>
      

    </div>

    <% if @spp.lunas? %>
      <div class="footer">
        <p>Terima kasih atas pembayaran Anda.</p>
        <p>Invoice ini adalah bukti pembayaran yang sah.</p>
      </div>
    <% end %>
  </div>
</body>
</html>