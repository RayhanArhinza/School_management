<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice SPP</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-4">
    <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8">
        <!-- Header -->
        <div class="text-center mb-2 relative pb-4">
            <h1 class="text-2xl font-bold text-blue-600 uppercase tracking-wider mb-2">
                Invoice Pembayaran SPP
            </h1>
            <div class="text-gray-600">
                No. Invoice: INV-<%= @spp.id %>
            </div>
            <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-36 h-1 bg-gradient-to-r from-blue-500 to-blue-600"></div>
        </div>

        <!-- School Info -->
        <div class="bg-gray-50 rounded-md p-6 mb-2">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">
                SEKOLAH MENENGAH ATAS
            </h2>
            <p class="text-gray-600 mb-2">
                <i class="fas fa-map-marker-alt mr-2"></i> Jl. Pendidikan No. 123
            </p>
            <p class="text-gray-600">
                <i class="fas fa-phone mr-2"></i> (021) 555-0123
            </p>
        </div>

        <!-- Info Grid -->
        <div class="grid md:grid-cols-2 gap-6 mb-2">
            <!-- Invoice Details -->
            <div class="bg-gray-50 p-6 rounded-md border-l-4 border-blue-500">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Detail Invoice</h3>
                <p class="mb-2"><span class="font-semibold">Tanggal:</span> <%= Time.current.strftime("%d %B %Y") %></p>
                <p>
                    <span class="font-semibold">Status:</span>
                    <span class="inline-block px-4 py-1 rounded-full text-sm font-semibold uppercase <%= @spp.lunas ? 'bg-green-500 text-white' : 'bg-red-500 text-white' %>">
                        <%= @spp.lunas ? 'LUNAS' : 'BELUM LUNAS' %>
                    </span>
                </p>
            </div>

            <!-- Student Info -->
            <div class="bg-gray-50 p-6 rounded-md border-l-4 border-blue-500">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Informasi Siswa</h3>
                <p class="mb-2"><span class="font-semibold">Nama:</span> <%= @spp.siswa.name %></p>
                <p class="mb-2"><span class="font-semibold">Kelas:</span> <%= @spp.siswa.kela.nama_kelas %></p>
                <p><span class="font-semibold">NISN:</span> <%= @spp.siswa.nisn %></p>
            </div>
        </div>

        <!-- Payment Table -->
        <div class="overflow-x-auto mb-8">
            <table class="w-full border-collapse shadow-sm">
                <thead>
                    <tr>
                        <th class="bg-blue-500 text-white p-4 text-left">Deskripsi</th>
                        <th class="bg-blue-500 text-white p-4 text-left">Periode</th>
                        <th class="bg-blue-500 text-white p-4 text-left">Jumlah</th>
                        <th class="bg-blue-500 text-white p-4 text-left">Status Pembayaran</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="hover:bg-gray-50">
                        <td class="border p-4">Pembayaran SPP</td>
                        <td class="border p-4"><%= @spp.bulan %> <%= @spp.tahun %></td>
                        <td class="border p-4"><%= @spp.biaya %></td>
                        <td class="border p-4">LUNAS</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <% if @spp.lunas? %>
        <!-- Footer -->
        <div class="text-center text-gray-600 mt-12 pt-6 border-t-2 border-dashed">
            <p class="mb-2">Terima kasih atas pembayaran Anda.</p>
            <p>Invoice ini adalah bukti pembayaran yang sah.</p>
        </div>
        <% end %>
    </div>
</body>
</html>